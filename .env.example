# ---------------------------------------------------------------------------
# V2P — VMware to Proxmox Migration Toolkit — example configuration
# Copy to `.env` (loaded automatically). Or just run with --demo.
# Crafted by SoyRage Agency — https://soyrage.es/
# ---------------------------------------------------------------------------

# ----- vCenter (read-only account is enough) -------------------------------
VCENTER_HOST=https://vcenter.corp.local
VCENTER_USER=readonly@vsphere.local
VCENTER_PASSWORD=
# vCenter usually presents a self-signed certificate → leave false unless trusted.
VCENTER_VERIFY_TLS=false

# ----- Try it without a vCenter --------------------------------------------
# "true" serves a realistic fabricated estate so you can run the whole toolkit.
V2P_DEMO=false

# ----- Output & estimation assumptions (tune per engagement) ---------------
# Where the PDF/HTML/plan/JSON are written.
V2P_OUT_DIR=./assessment
# Assumed conversion throughput per disk (MB/s) for the time estimate.
V2P_THROUGHPUT_MBPS=250
# How many VMs you migrate in parallel (affects wall-clock time).
V2P_PARALLEL=2
# Annual vSphere cost per CPU core (USD) — Broadcom per-core licensing.
V2P_VSPHERE_PER_CORE=350
# Annual Proxmox VE subscription per socket (USD).
V2P_PROXMOX_PER_SOCKET=620

# ----- Web UI --------------------------------------------------------------
V2P_WEB_HOST=127.0.0.1
V2P_WEB_PORT=4700

# Log verbosity: debug | info | warn | error
V2P_LOG_LEVEL=info
